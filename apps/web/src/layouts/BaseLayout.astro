---
import '../styles/global.css';
import '@fontsource/public-sans/400.css';
import '@fontsource/public-sans/500.css';
import '@fontsource/public-sans/600.css';
import ThemeToggle from '../components/ThemeToggle.svelte';
import SearchBar from '../components/SearchBar.svelte';
import BackToTop from '../components/BackToTop.svelte';
import { TITLE_NAMES } from '../data/title-names';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'US Code Tracker',
  description = 'Track changes to the United States Code with Git-based version control.',
} = Astro.props;

const base = import.meta.env.BASE_URL;

// Determine the current title number from the URL for highlighting
const pathname = Astro.url.pathname;
const titleMatch = pathname.match(/\/browse\/title-(\d+)/);
const currentTitleNum = titleMatch ? Number(titleMatch[1]) : null;

// Build sorted title entries
const titleEntries = Object.entries(TITLE_NAMES)
  .map(([num, name]) => ({ num: Number(num), name }))
  .sort((a, b) => a.num - b.num);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta name="base-url" content={base} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="alternate" type="application/rss+xml" title="US Code Tracker — Recent Updates" href={`${base}feed.xml`} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title === 'US Code Tracker' ? title : `${title} | US Code Tracker`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:site_name" content="US Code Tracker" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title === 'US Code Tracker' ? title : `${title} | US Code Tracker`} />
    <meta name="twitter:description" content={description} />
    <!-- CSP: defense-in-depth against XSS -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.github.com;" />
    <title>{title === 'US Code Tracker' ? title : `${title} | US Code Tracker`}</title>
    <script is:inline>
      // Apply theme before render to prevent flash
      (function () {
        var stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="h-full bg-warm-white text-slate dark:bg-navy-dark dark:text-gray-100">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:bg-navy focus:px-4 focus:py-2 focus:text-white focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-navy">
      Skip to content
    </a>
    <div class="flex h-full flex-col lg:flex-row">
      <!-- Sidebar — nav column -->
      <aside class="w-full border-b border-gray-200 bg-warm-gray font-sans lg:w-64 lg:flex-shrink-0 lg:border-b-0 lg:border-r dark:border-gray-800 dark:bg-[#0B1926] lg:flex lg:flex-col lg:h-full 2xl:w-60">
        <div class="flex items-center justify-between p-4 lg:flex-col lg:items-start lg:gap-4">
          <a href={base} class="text-lg font-bold text-navy dark:text-amber">
            US Code Tracker
          </a>
          <span class="hidden text-xs text-slate dark:text-gray-500 lg:inline">Current through PL 119-73</span>
          <div class="flex items-center gap-2 lg:w-full lg:flex-col lg:items-stretch">
            <ThemeToggle client:load />
            <SearchBar client:load />
          </div>
        </div>
        <button
          id="menu-toggle"
          class="mx-4 mb-2 rounded border border-gray-300 px-2 py-1 text-xs font-sans lg:hidden dark:border-gray-700"
          aria-expanded="false"
          aria-controls="main-nav"
          aria-label="Open menu"
        >
          Menu
        </button>
        <nav id="main-nav" class="hidden px-4 pb-4 font-sans lg:flex lg:min-h-0 lg:flex-1 lg:flex-col" aria-label="Main navigation">
          <label for="title-filter" class="sr-only">Filter titles</label>
          <input
            type="text"
            id="title-filter"
            placeholder="Filter titles…"
            autocomplete="off"
            class="mb-2 w-full rounded border border-gray-300 bg-white px-2 py-1 text-sm text-gray-900 placeholder-gray-400 focus:border-navy focus:outline-none focus:ring-1 focus:ring-navy dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-500 dark:focus:border-amber dark:focus:ring-amber"
          />
          <ul id="title-list" class="space-y-0.5 overflow-y-auto text-sm lg:max-h-[calc(100vh-280px)]">
            {titleEntries.map(({ num, name }) => {
              const isActive = currentTitleNum === num;
              const linkClass = isActive
                ? 'block rounded px-2 py-1 bg-navy/10 font-semibold text-navy dark:bg-amber/10 dark:text-amber'
                : 'block rounded px-2 py-1 text-slate hover:bg-gray-200 hover:text-navy dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-amber';
              return (
                <li data-title-num={num} data-title-name={name.toLowerCase()}>
                  <a href={`${base}browse/title-${num}/`} class={linkClass} aria-current={isActive ? 'page' : undefined}>
                    {num} &mdash; {name}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Main content — becomes flex at 2xl for 3-column precedent panel -->
      <main id="main-content" class="min-h-0 flex-1 overflow-y-auto 2xl:flex 2xl:flex-row">
        <article class="prose prose-lg prose-gray mx-auto max-w-3xl p-6 font-serif leading-relaxed dark:prose-invert lg:p-10 2xl:mx-0 2xl:flex-1 2xl:min-w-0">
          <slot />
        </article>

        <!-- Footer -->
        <footer class="border-t border-gray-200 px-6 py-8 font-sans text-sm text-slate dark:border-gray-800 dark:text-gray-400">
          <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 sm:grid-cols-3">
            <div>
              <h2 class="mb-2 text-xs font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300">About</h2>
              <p class="text-xs leading-relaxed">
                Independent civic tech project tracking changes to U.S. federal law.
              </p>
              <p class="mt-1 text-xs leading-relaxed">
                Not affiliated with any government agency.
              </p>
            </div>
            <div>
              <h2 class="mb-2 text-xs font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300">Resources</h2>
              <ul class="space-y-2 text-xs">
                <li>
                  <a href="https://uscode.house.gov/" class="inline-block py-1 underline hover:text-teal" rel="noopener noreferrer" target="_blank">
                    Official U.S. Code (OLRC)
                  </a>
                </li>
                <li>
                  <a href="https://github.com/civic-source/us-code" class="inline-block py-1 underline hover:text-teal" rel="noopener noreferrer" target="_blank">
                    Source Data (GitHub)
                  </a>
                </li>
                <li>
                  <a href="https://github.com/civic-source/us-code-tracker" class="inline-block py-1 underline hover:text-teal" rel="noopener noreferrer" target="_blank">
                    Pipeline Code (GitHub)
                  </a>
                </li>
              </ul>
            </div>
            <div>
              <h2 class="mb-2 text-xs font-bold uppercase tracking-wide text-gray-700 dark:text-gray-300">Legal</h2>
              <p class="text-xs leading-relaxed">Code: Apache 2.0 License</p>
              <p class="mt-1 text-xs leading-relaxed">Data: CC0 Public Domain</p>
              <p class="mt-1 text-xs leading-relaxed">Current through PL 119-73</p>
            </div>
          </div>
        </footer>
      </main>
    </div>
    <script is:inline>
      (function () {
        // Mobile menu toggle
        var btn = document.getElementById('menu-toggle');
        var nav = document.getElementById('main-nav');
        if (!btn || !nav) return;
        btn.addEventListener('click', function () {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          btn.setAttribute('aria-label', expanded ? 'Open menu' : 'Close menu');
          nav.classList.toggle('hidden', expanded);
        });

        // Title filter
        var filter = document.getElementById('title-filter');
        var list = document.getElementById('title-list');
        if (!filter || !list) return;
        var items = list.querySelectorAll('li');
        filter.addEventListener('input', function () {
          var query = filter.value.toLowerCase().trim();
          for (var i = 0; i < items.length; i++) {
            var li = items[i];
            var num = li.getAttribute('data-title-num') || '';
            var name = li.getAttribute('data-title-name') || '';
            var match = !query || num.indexOf(query) !== -1 || name.indexOf(query) !== -1;
            li.style.display = match ? '' : 'none';
          }
        });
      })();
    </script>
    <BackToTop client:load />
  </body>
</html>
